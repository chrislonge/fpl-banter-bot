# FPL
FPL_LEAGUE_ID=your-league-id
FPL_LEAGUE_TYPE=h2h

# Telegram (optional — omit both to run in data-collection-only mode)
# TELEGRAM_BOT_TOKEN=your-token-from-botfather
# TELEGRAM_CHAT_ID=your-group-chat-id

# Webhook (required when Telegram is configured)
# WEBHOOK_BASE_URL=https://your-host.your-tailnet.ts.net   # publicly reachable URL (no trailing slash)
# WEBHOOK_PORT=8080                                        # port for the local HTTP server (default: 8080)
# WEBHOOK_SECRET=                                          # auto-generated if omitted

# Database
# Local dev: use @localhost:5432 (bot runs on host, DB in Docker)
# Docker/Pi: use @db:5432 (bot and DB are both containers — "db" is the service name)
DATABASE_URL=postgres://fplbot:password@localhost:5432/fplbanterbot?sslmode=disable
STORE_TEST_DATABASE_URL=postgres://fplbot:password@localhost:5432/fplbanterbot_test?sslmode=disable

# Polling (optional overrides — values in seconds)
POLL_IDLE_INTERVAL=21600
POLL_LIVE_INTERVAL=900
POLL_PROCESSING_INTERVAL=600

# Logging
LOG_LEVEL=info

# To backfill historical gameweeks:
#   Local (Go required):  make backfill
#   Docker (Pi/server):   make docker-backfill
