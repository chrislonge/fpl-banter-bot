# FPL
FPL_LEAGUE_ID=your-league-id
FPL_LEAGUE_TYPE=h2h

# Telegram
TELEGRAM_BOT_TOKEN=your-token-from-botfather
TELEGRAM_CHAT_ID=your-group-chat-id

# Database
DATABASE_URL=postgres://fplbot:password@localhost:5432/fplbanterbot?sslmode=disable
STORE_TEST_DATABASE_URL=postgres://fplbot:password@localhost:5432/fplbanterbot_test?sslmode=disable

# Polling (optional overrides — values in seconds)
POLL_IDLE_INTERVAL=21600
POLL_LIVE_INTERVAL=900
POLL_PROCESSING_INTERVAL=600

# Logging
LOG_LEVEL=info

# To backfill historical gameweeks: make backfill
